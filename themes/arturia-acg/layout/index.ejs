<%
  function decodeEntities(text) {
    return String(text || '')
      .replace(/&amp;/g, '&')
      .replace(/&lt;/g, '<')
      .replace(/&gt;/g, '>')
      .replace(/&quot;/g, '"')
      .replace(/&apos;/g, "'")
      .replace(/&nbsp;/g, ' ')
      .replace(/&#x([0-9a-fA-F]+);/g, function(_, hex) { return String.fromCharCode(parseInt(hex, 16)); })
      .replace(/&#([0-9]+);/g, function(_, code) { return String.fromCharCode(parseInt(code, 10)); });
  }

  function normalizedExcerpt(post) {
    var source = post.content || post.excerpt || '';
    return decodeEntities(strip_html(source))
      .replace(/\[+/g, '')
      .replace(/\]+/g, '')
      .replace(/\s+/g, ' ')
      .trim()
      .slice(0, 140) + '...';
  }
%>

<section class="post-list">
  <% page.posts.each(function(post){ %>
    <article class="post-card post-card-horizontal">
      <a class="post-cover" href="<%= url_for(post.path) %>">
        <img src="<%- post.cover || theme.default_cover || '' %>" alt="<%= post.title %>" loading="lazy" decoding="async" style="width: 100%; height: 100%; object-fit: cover;">
      </a>
      <div class="post-body">
        <h2 class="post-title"><a href="<%= url_for(post.path) %>"><%= post.title %></a></h2>

        <div class="post-meta">
          <% var hasCategories = post.categories && post.categories.length; %>
          <% var hasTags = post.tags && post.tags.length; %>
          <span class="meta-item"><i class="far fa-calendar-alt"></i> <%- date(post.date, "YYYY-MM-DD") %></span>
          <% if (hasCategories) { %>
            <span class="meta-divider"></span>
            <span class="meta-item"><i class="fas fa-folder-open"></i><%- list_categories(post.categories, {show_count: false, style: 'none', separator: ' '}) %></span>
          <% } %>
          <% if (hasTags) { %>
            <span class="meta-divider"></span>
            <span class="meta-item"><i class="fas fa-tags"></i><%- list_tags(post.tags, {show_count: false, style: 'none', separator: ' '}) %></span>
          <% } %>
        </div>

        <p class="post-excerpt"><%= normalizedExcerpt(post) %></p>
      </div>
    </article>
  <% }) %>
</section>

<%- partial('_partial/pagination') %>
