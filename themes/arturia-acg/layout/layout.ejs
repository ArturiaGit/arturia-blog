<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
  <%
    var currentTitle = page.title;
    if (is_archive()) {
      currentTitle = '时空归档';
    } else if (is_category()) {
      currentTitle = '领域: ' + page.category;
    } else if (is_tag()) {
      currentTitle = '印记: ' + page.tag;
    }
  %>
  <title><% if (is_home()) { %><%= config.title %> | <%= config.subtitle %><% } else if (currentTitle) { %><%= currentTitle %> | <%= config.title %><% } else { %><%= config.title %><% } %></title>
  <link rel="icon" type="image/png" sizes="128x128" href="<%= url_for('/img/favicon.png') %>" />
  <link rel="apple-touch-icon" sizes="180x180" href="<%= url_for('/img/favicon.png') %>" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;500;600;700&family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="<%= url_for('/css/style.css') %>" />
  <style>
    :root {
      --typing-speed: <%= theme.typewriter_speed || '4s' %>;
      --bg-blur: <%= (theme.background_style && theme.background_style.blur_radius) || '8px' %>;
      --bg-mask-opacity: <%= (theme.background_style && theme.background_style.mask_opacity) || '0.5' %>;
      --bg-grid-opacity: <%= (theme.background_style && theme.background_style.grid_opacity) || '0.2' %>;
    }
  </style>
</head>
<%
  var pageClass = 'page-generic';
  if (is_home()) {
    pageClass = 'page-home';
  } else if (is_post()) {
    pageClass = 'page-post';
  } else if (is_archive()) {
    pageClass = 'page-archive';
  } else if (is_tag() || page.type === 'tags') {
    pageClass = 'page-tag';
  } else if (is_category() || page.type === 'categories') {
    pageClass = 'page-category';
  }
%>
<body class="<%= pageClass %>">
  <div class="global-background-overlay">
    <div class="holographic-grid"></div>
  </div>
  <nav class="top-nav">
    <div class="nav-inner">
      <a class="logo" href="<%= url_for('/') %>"><%= config.title %></a>
      <ul class="nav-menu">
        <% for (var label in theme.menu) { %>
          <% var item = theme.menu[label].split('||') %>
          <% var link = item[0].trim() %>
          <% var icon = (item[1] || '').trim() %>
          <% if (label !== '环境光') { %>
          <li>
            <% if (label === '搜索') { %>
              <a id="nav-search-btn" href="javascript:void(0);" aria-haspopup="dialog" aria-expanded="false">
                <span class="nav-icon"><i class="<%= icon %>"></i></span>
                <span><%= label %></span>
              </a>
            <% } else { %>
              <a href="<%= url_for(link) %>">
                <span class="nav-icon"><i class="<%= icon %>"></i></span>
                <span><%= label %></span>
              </a>
            <% } %>
          </li>
          <% } %>
        <% } %>
        <li>
          <a id="env-light-trigger" href="javascript:void(0);">
            <span class="nav-icon"><i class="fas fa-magic"></i></span>
            <span>环境光</span>
          </a>
        </li>
      </ul>
    </div>
  </nav>

  <% var heroCover = (is_post() && page.cover) ? page.cover : (theme.default_cover || ''); %>
  <% if (is_home()) { %>
  <header class="hero" <% if (heroCover) { %>style="background-image: url('<%= heroCover %>');"<% } %>>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1 class="hero-slogan"><span class="typewriter"><%= theme.hero.slogan %></span></h1>
    </div>
    <div class="hero-arrow"><i class="fas fa-chevron-down"></i></div>
  </header>

  <% } else if (is_archive() || is_tag() || is_category() || page.type === 'tags' || page.type === 'categories') { %>
  <div class="nav-spacer" style="height: 110px;"></div>

  <% } else { %>
  <header class="page-hero" <% if (heroCover) { %>style="background-image: url('<%= heroCover %>');"<% } %>>
    <div class="page-hero-overlay"></div>
    <div class="page-hero-inner">
      <h1><%= page.title || config.title %></h1>
    </div>
  </header>
  <% } %>

  <main class="main">
    <div class="layout-shell">
      <section class="content-area">
        <%- body %>
      </section>
      <aside class="sidebar-area">
        <%- partial('_widget/sidebar') %>
      </aside>
    </div>
  </main>

  <%
    var searchPath = (((config.search && config.search.path) ? config.search.path : 'search.json') + '').replace(/^\/+/, '');
    var searchRecentPosts = [];
    site.posts.sort('date', -1).limit(5).forEach(function(post) {
      searchRecentPosts.push({
        title: post.title,
        url: url_for(post.path),
        cover: post.cover || theme.default_cover || '',
        date: date(post.date, 'YYYY-MM-DD')
      });
    });

    var searchHotTags = [];
    site.tags.sort('length', -1).limit(8).forEach(function(tag) {
      searchHotTags.push({
        name: tag.name,
        count: tag.length,
        url: url_for(tag.path)
      });
    });

    var searchHotCategories = [];
    site.categories.sort('length', -1).limit(6).forEach(function(category) {
      searchHotCategories.push({
        name: category.name,
        count: category.length,
        url: url_for(category.path)
      });
    });

    var searchMetaMap = {};
    site.posts.forEach(function(post) {
      searchMetaMap[url_for(post.path)] = {
        date: date(post.date, 'YYYY-MM-DD'),
        cover: post.cover || theme.default_cover || '',
        excerpt: strip_html(post.excerpt || post.content || '').replace(/\s+/g, ' ').trim().slice(0, 160)
      };
    });
  %>
  <div class="search-overlay" id="search-overlay"></div>
  <div
    class="search-panel"
    id="search-panel"
    aria-hidden="true"
    aria-modal="true"
    role="dialog"
    data-search-path="<%= url_for('/' + searchPath) %>"
  >
    <div class="search-container">
      <div class="search-shell">
        <div class="search-header">
          <div class="search-heading">
            <span class="search-kicker">STAR TRAIL RETRIEVAL</span>
            <h2 class="search-title">星轨检索舱</h2>
            <p class="search-description">从标题、标签到正文片段，统一扫描你整座博客的内容轨迹。</p>
          </div>
          <button class="search-close" id="search-close" type="button" aria-label="关闭搜索">
            <i class="fas fa-xmark"></i>
          </button>
        </div>

        <div class="search-box">
          <span class="search-icon"><i class="fas fa-satellite-dish"></i></span>
          <input
            id="search-input"
            class="search-input"
            type="text"
            placeholder="搜索文章 / 标签 / 分类 / 关键词"
            autocomplete="off"
            spellcheck="false"
          />
        </div>

        <div class="search-toolbar">
          <div class="search-status" id="search-status">
            <span class="search-status-label" id="search-status-label">检索舱待命</span>
            <span class="search-status-text" id="search-status-text">按下 Ctrl/⌘ + K 或直接输入关键词开始搜索</span>
          </div>
          <div class="search-shortcuts">
            <span class="search-shortcut"><kbd>Ctrl</kbd><span>/</span><kbd>⌘</kbd><span>+</span><kbd>K</kbd></span>
            <span class="search-shortcut"><kbd>Esc</kbd><span>关闭</span></span>
            <span class="search-shortcut"><kbd>↑</kbd><span>/</span><kbd>↓</kbd><span>导航</span></span>
          </div>
        </div>

        <div class="search-content">
          <div class="search-view search-default-view" id="search-default-view">
            <div class="search-default-grid">
              <section class="search-default-card search-intro-card">
                <span class="search-card-kicker">SCAN MODES</span>
                <h3>不只是找文章，而是直接检索整套内容体系</h3>
                <p>搜索会优先命中标题与标签，再向正文延展，并自动提取最接近命中词的上下文片段。</p>
                <div class="search-feature-list">
                  <span class="search-feature-pill"><i class="fas fa-bullseye"></i> 标题高权重命中</span>
                  <span class="search-feature-pill"><i class="fas fa-tags"></i> 标签 / 分类联动</span>
                  <span class="search-feature-pill"><i class="fas fa-wand-magic-sparkles"></i> 命中片段摘要</span>
                </div>
              </section>

              <section class="search-default-card">
                <div class="search-card-header">
                  <span class="search-card-kicker">LATEST LOGS</span>
                  <h3>最近更新</h3>
                </div>
                <div class="search-suggestion-list">
                  <% searchRecentPosts.forEach(function(post) { %>
                    <a class="search-suggestion-item" href="<%= post.url %>">
                      <% if (post.cover) { %>
                        <span class="search-suggestion-cover">
                          <img src="<%= post.cover %>" alt="<%= post.title %>" />
                        </span>
                      <% } %>
                      <span class="search-suggestion-main">
                        <span class="search-suggestion-title"><%= post.title %></span>
                        <span class="search-suggestion-meta"><i class="far fa-calendar-alt"></i><%= post.date %></span>
                      </span>
                    </a>
                  <% }) %>
                </div>
              </section>
            </div>

            <div class="search-default-grid search-default-grid-secondary">
              <section class="search-default-card">
                <div class="search-card-header">
                  <span class="search-card-kicker">HOT TAGS</span>
                  <h3>热门标签</h3>
                </div>
                <div class="search-chip-cloud" id="search-quick-filters">
                  <% searchHotTags.forEach(function(tag) { %>
                    <button class="search-chip-button" type="button" data-search-term="<%= tag.name %>">
                      <i class="fas fa-hashtag"></i>
                      <span><%= tag.name %></span>
                      <small><%= tag.count %></small>
                    </button>
                  <% }) %>
                </div>
              </section>

              <section class="search-default-card">
                <div class="search-card-header">
                  <span class="search-card-kicker">TOP CATEGORIES</span>
                  <h3>分类入口</h3>
                </div>
                <div class="search-chip-cloud">
                  <% searchHotCategories.forEach(function(category) { %>
                    <button class="search-chip-button is-category" type="button" data-search-term="<%= category.name %>">
                      <i class="fas fa-folder-open"></i>
                      <span><%= category.name %></span>
                      <small><%= category.count %></small>
                    </button>
                  <% }) %>
                </div>
              </section>
            </div>
          </div>

          <div class="search-view search-results-view" id="search-results-view" hidden>
            <ul id="search-results" class="search-results" role="listbox" aria-label="搜索结果"></ul>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script id="search-post-meta" type="application/json"><%- JSON.stringify(searchMetaMap) %></script>

  <script defer src="<%= config.root %>js/search.js"></script>
  <script defer src="<%= config.root %>js/code-block.js"></script>
  <script defer src="<%= config.root %>js/keyword-card.js"></script>
  <script>
    (function() {
      var nav = document.querySelector('.top-nav');
      if (!nav) return;
      var toggleNav = function() {
        if (window.scrollY > 50) {
          nav.classList.add('nav-scrolled');
        } else {
          nav.classList.remove('nav-scrolled');
        }
      };
      toggleNav();
      window.addEventListener('scroll', toggleNav, { passive: true });
    })();
  </script>

  <div id="cyber-bg-1" style="position: fixed; inset: 0; z-index: -1000; background-size: cover; background-position: center; transition: opacity 0.8s ease; opacity: 1;"></div>
  <div id="cyber-bg-2" style="position: fixed; inset: 0; z-index: -999; background-size: cover; background-position: center; transition: opacity 0.8s ease; opacity: 0;"></div>

  <script>
  document.addEventListener('DOMContentLoaded', () => {
    const bgList = <%- JSON.stringify(get_local_bgs()) %>;
    if (!bgList || bgList.length === 0) return;

    const bg1 = document.getElementById('cyber-bg-1');
    const bg2 = document.getElementById('cyber-bg-2');
    const trigger = document.getElementById('env-light-trigger');

    // 1. 姣忔棩鑳屾櫙閿佸畾锛氬綋澶╁浐瀹氳儗鏅?URL锛屾鏃ユ墠閲嶆柊璁＄畻锛堟柊澧炲浘鐗囧綋澶╀笉褰卞搷锛?
    const dayMs = 24 * 60 * 60 * 1000;
    const getTodayKey = () => {
      const d = new Date();
      return `${d.getFullYear()}-${d.getMonth() + 1}-${d.getDate()}`;
    };

    const now = new Date();
    const localMidnight = new Date(now.getFullYear(), now.getMonth(), now.getDate()).getTime();
    const dailyIdx = Math.floor(localMidnight / dayMs) % bgList.length;

    const dailyDateKey = 'arturia_daily_bg_date';
    const dailyBgUrlKey = 'arturia_daily_bg_url';
    const todayKey = getTodayKey();

    const savedDate = localStorage.getItem(dailyDateKey);
    const savedBgUrl = localStorage.getItem(dailyBgUrlKey);

    let currentBgUrl = '';
    if (savedDate === todayKey && savedBgUrl) {
      currentBgUrl = savedBgUrl;
    } else {
      currentBgUrl = bgList[dailyIdx] || '';
      localStorage.setItem(dailyDateKey, todayKey);
      localStorage.setItem(dailyBgUrlKey, currentBgUrl);
    }

    if (!currentBgUrl) {
      currentBgUrl = bgList[0] || '';
    }

    let activeLayer = 1;
    let isSwitching = false; // 绔炴€侀攣

    // 2. 鏍稿績淇锛氬埄鐢?Hexo 鐨?EJS 鍔ㄦ€佹敞鍏ュ綋鍓嶉〉闈㈢殑涓撳睘灏侀潰 (鑻ユ湁)
    const pageCover = "<%- page.cover ? page.cover : '' %>";

    // 3. 鏅鸿兘璺敱锛氫紭鍏堟樉绀洪〉闈笓灞炲皝闈紝娌℃湁鍒欎娇鐢ㄥ綋澶╅攣瀹氳儗鏅?
    const initialBgUrl = pageCover || currentBgUrl || '';
    if (initialBgUrl) {
      bg1.style.backgroundImage = `url(${initialBgUrl})`;
    }

    // 4. 涓€閿疆鎾笎鍙橀€昏緫
    if (trigger) {
      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        if (isSwitching) return; // 闃叉姈锛岄槻姝㈢柉鐙傜偣鍑?
        isSwitching = true;

        // 璁＄畻涓嬩竴寮犲叏灞€澹佺焊锛堝綋澶╅攣瀹氫负鎵嬪姩缁撴灉锛?
        const currentIdx = bgList.indexOf(currentBgUrl);
        const nextBgUrl = bgList[(currentIdx + 1 + bgList.length) % bgList.length];

        const nextDiv = activeLayer === 1 ? bg2 : bg1;
        const currDiv = activeLayer === 1 ? bg1 : bg2;

        // 闅愬紡棰勫姞杞斤細鏃犵櫧灞忋€佹棤闂儊銆佹棤閲嶅彔
        const img = new Image();
        img.src = nextBgUrl;
        img.onload = () => {
          nextDiv.style.backgroundImage = `url(${nextBgUrl})`;
          nextDiv.style.opacity = 1; // 鏂扮敾甯冩贰鍏ヤ寒璧?
          currDiv.style.opacity = 0; // 鏃х敾甯冩贰鍑洪殣鍘?

          activeLayer = activeLayer === 1 ? 2 : 1;
          currentBgUrl = nextBgUrl;
          localStorage.setItem(dailyDateKey, todayKey);
          localStorage.setItem(dailyBgUrlKey, currentBgUrl);

          // 鍔ㄧ敾鏃堕棿涓?0.8s锛岀瓑寰呭姩鐢荤粨鏉熷悗瑙ｉ攣
          setTimeout(() => { isSwitching = false; }, 800);
        };

        img.onerror = () => { isSwitching = false; };
      });
    }
  });
  </script>
</body>
</html>
